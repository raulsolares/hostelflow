# HostelFlow - Variables de entorno (producción)
# Copia este archivo como .env y ajusta los valores

# Clave secreta para JWT (OBLIGATORIA en producción)
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Si ENV=production y HOSTELFLOW_SECRET falta o es el valor por defecto, la app no arranca
HOSTELFLOW_SECRET=hostelflow-dev-secret-2026

# Base de datos (SQLite por defecto, o PostgreSQL)
DATABASE_URL=sqlite:///./hostelflow.db

# Puerto
PORT=8000

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:8000

# Web Push (VAPID) — notificaciones push autoalojadas, sin proveedor externo.
# Si se dejan vacías, la app autogenera un par de claves EC P-256 al arrancar
# y las persiste en vapid_keys.json (raíz del repo, ignorado por git). Eso es
# suficiente para dev, pero en producción cada reinicio sin este archivo
# invalidaría las suscripciones existentes (el cliente pide re-suscribirse
# contra la nueva clave pública) — define estas 3 vars explícitamente.
#
# Genera un par de claves con:
#   python -c "from py_vapid import Vapid02 as Vapid; from py_vapid.utils import b64urlencode; from cryptography.hazmat.primitives import serialization; v = Vapid(); v.generate_keys(); print('VAPID_PRIVATE_KEY='); print(v.private_pem().decode()); print('VAPID_PUBLIC_KEY=' + b64urlencode(v.public_key.public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)))"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_SUB=mailto:admin@hostelflow.local
